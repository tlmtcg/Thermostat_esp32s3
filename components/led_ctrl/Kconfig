menu "LED Control Configuration"

    config LED_STRIP_GPIO
        int "GPIO number for the RGB LED"
        range 0 48
        default 48
        help
            The GPIO pin connected to the WS2812/NeoPixel LED.

    config LED_STRIP_BRIGHTNESS
        int "Maximum LED Brightness (0-255)"
        range 0 255
        default 50

    config LED_ALARM_COLOR_RED
        int "Alarm Red Intensity"
        range 0 255
        default 255

    config LED_ALARM_BLINK_SPEED_MS
        int "Alarm Blink Speed (ms)"
        default 200

endmenu