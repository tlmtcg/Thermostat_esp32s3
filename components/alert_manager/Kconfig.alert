menu "Alerts Configuration"

    config MAX_ALERT_LOGS
        int "MAX ALERT LOGS"
        default 10
        help
            Max number of alert logs.

    config MAX_ACTIVE_ALERTS
        int "MAX ACTIVE ALERTS"
        default 5
        help
            Max number of active alerts.

    config MAX_HISTORY_ALERTS
        int "MAX HISTORY ALERTS"
        default 50
        help
            Max number of historical alerts to keep.
            
    endmenu