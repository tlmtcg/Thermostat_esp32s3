
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="common.css" />
    <title>OLED Composer Pro</title>
    <style>
      :root {
        --oled-yellow: #ffee00;
        --oled-blue: #00ccff;
        --oled-bg: #050505;
      }

      /* Simulation de l'écran OLED bicolore */
      .oled-display {
        width: 256px;
        height: 128px; /* Échelle x2 */
        background-color: var(--oled-bg);
        border: 6px solid #333;
        border-radius: 8px;
        position: relative;
        font-family: "monospace";
        box-shadow: 0 0 20px rgba(0, 0, 0, 0.5);
        margin: 10px auto;
        overflow: hidden;
      }
      .zone-yellow {
        height: 25%;
        width: 100%;
        border-bottom: 1px dashed #222;
        color: var(--oled-yellow);
        font-weight: bold;
        padding: 4px;
      }
      .zone-blue {
        height: 75%;
        width: 100%;
        color: var(--oled-blue);
        padding: 4px;
      }
      .pixel-text {
        position: absolute;
        white-space: pre;
        font-size: 14px;
        pointer-events: none;
      }

      .composer-grid {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 20px;
      }
      .controls {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .chip-group {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
        margin: 10px 0;
      }
      .chip {
        background: #333;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 0.75rem;
        cursor: pointer;
        border: 1px solid #444;
      }
      .chip:hover {
        background: var(--orange);
      }

      .tool-row {
        display: flex;
        gap: 8px;
        align-items: center;
      }
      input[type="number"] {
        width: 70px;
      }
      textarea {
        width: 100%;
        height: 80px;
        resize: none;
      }

      .box h3 {
        margin-bottom: 10px;
        font-size: 0.9rem;
        color: #aaa;
        text-transform: uppercase;
      }
    </style>
  </head>

  <body>
    <div id="navbar"></div>
    <h1 class="page-title">OLED Composer Pro</h1>

    <div class="composer-grid">
      <!-- COLONNE GAUCHE : ÉDITION -->
      <div class="left-col">
        <div class="box">
          <h3><i class="icon">📝</i> Texte & Position</h3>
          <div class="controls">
            <div class="tool-row">
              <label>X:</label
              ><input type="number" id="x" value="0" min="0" max="127" />
              <label>Y:</label
              ><input type="number" id="y" value="0" min="0" max="63" />
              <button class="secondary" onclick="insertVar('{IP}')">
                Add IP
              </button>
              <button class="secondary" onclick="insertVar('{TEMP}')">
                Add Temp
              </button>
            </div>
            <textarea
              id="text"
              placeholder="Entrez votre texte ici..."
            ></textarea>

            <div class="tool-row">
              <button onclick="sendWrite()">Enregistrer sur l'écran</button>
              <button class="danger" onclick="clearOLED()">Effacer</button>
            </div>
          </div>

          <h3><i class="icon">🖼️</i> Icônes Rapides</h3>
          <div class="chip-group">
            <div class="chip" onclick="addText(' [WiFi] ')">📶 WiFi</div>
            <div class="chip" onclick="addText(' [BT] ')">🔹 Bluetooth</div>
            <div class="chip" onclick="addText(' [!] ')">⚠️ Warning</div>
            <div class="chip" onclick="addText(' OK ')">✅ Check</div>
            <div class="chip" onclick="addText(' ❤ ')">❤️ Heart</div>
          </div>
        </div>

        <div class="box">
          <h3><i class="icon">⚙️</i> Options d'affichage</h3>
          <button class="secondary" onclick="invert(true)">Inversion ON</button>
          <button class="secondary" onclick="invert(false)">
            Inversion OFF
          </button>
        </div>
      </div>

      <!-- COLONNE DROITE : PREVIEW -->
      <div class="right-col">
        <div class="box" style="position: sticky; top: 20px">
          <h3>Aperçu (128x64)</h3>
          <div class="oled-display" id="display-root">
            <div class="zone-yellow"></div>
            <div class="zone-blue"></div>
            <div
              id="preview-text"
              class="pixel-text"
              style="left: 0; top: 0"
            ></div>
          </div>
          <p style="font-size: 0.7rem; color: #666; margin-top: 10px">
            * L'aperçu simule la séparation physique des couleurs de votre
            écran.
          </p>
        </div>
      </div>
    </div>

    <script>
      const BASE = "/api/oled";

      function insertVar(v) {
        const tx = document.getElementById("text");
        tx.value += v;
        updatePreview();
      }

      function addText(t) {
        document.getElementById("text").value += t;
        updatePreview();
      }

      async function sendWrite() {
        const payload = {
          x: parseInt(document.getElementById("x").value || 0),
          y: parseInt(document.getElementById("y").value || 0),
          text: document.getElementById("text").value,
        };
        await fetch(BASE + "/text", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
      }

      async function clearOLED() {
        await fetch(BASE + "/clear", { method: "POST" });
        document.getElementById("text").value = "";
        updatePreview();
      }

      async function invert(state) {
        await fetch(BASE + "/invert", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ invert: state }),
        });
      }

      function updatePreview() {
        const x = document.getElementById("x").value || 0;
        const y = document.getElementById("y").value || 0;
        let t = document.getElementById("text").value;

        // Simulation du rendu des variables
        const simulatedText = t
          .replace(/{IP}/g, "192.168.1.42")
          .replace(/{TEMP}/g, "24.5°C");

        const p = document.getElementById("preview-text");

        // Mise à jour du contenu
        p.textContent = simulatedText;

        // Positionnement (x2 pour la visibilité sur PC)
        p.style.left = x * 2 + "px";
        p.style.top = y * 2 + "px";

        // LOGIQUE DE COULEUR AUTOMATIQUE :
        // Sur un SSD1306 bicolore, la zone jaune fait environ 16 pixels de haut.
        if (y < 16) {
          p.style.color = "var(--oled-yellow)";
        } else {
          p.style.color = "var(--oled-blue)";
        }
      }

      // Listeners pour mise à jour temps réel
      document.getElementById("text").addEventListener("input", updatePreview);
      document.getElementById("x").addEventListener("input", updatePreview);
      document.getElementById("y").addEventListener("input", updatePreview);

      updatePreview();
    </script>
  </body>
</html>
