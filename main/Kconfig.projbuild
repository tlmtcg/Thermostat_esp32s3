menu "Configuration Thermostat"

    menu "LED Control Configuration"

    config LED_STRIP_GPIO
            int "GPIO number for the RGB LED"
            range 0 48
            default 48
            help
                The GPIO pin connected to the WS2812/NeoPixel LED. 
                Default is 48 on most ESP32-S3 DevKits.

        config LED_STRIP_BRIGHTNESS
            int "Maximum LED Brightness (0-255)"
            range 0 255
            default 50
            help
                Global brightness limit to prevent eye strain and high current draw.
                A value of 50 is usually sufficient for indoor use.

        config LED_ALARM_COLOR_RED
            int "Alarm Red Intensity"
            range 0 255
            default 255
            help
                Red component intensity during alarm blinks.

        config LED_ALARM_BLINK_SPEED_MS
            int "Alarm Blink Speed (ms)"
            default 200
            help
                Duration of the 'on' and 'off' phases during an alarm blink.

    endmenu

    menu "Alerts Configuration"

    config MAX_ALERT_LOGS
        int "MAX ALERT LOGS"
        default 10
        help
            Max number of alert logs.

    config MAX_ACTIVE_ALERTS
        int "MAX ACTIVE ALERTS"
        default 5
        help
            Max number of active alerts.
        
    endmenu

    menu "Freebox FTP Configuration"

        config FB_FTP_HOST
            string "IP de la Freebox"
            default "192.168.0.254"
            help
                L'adresse IP locale de votre Freebox.

        config FREEBOX_FTP_USER
            string "FTP Username"
            default "freebox"

        config FREEBOX_FTP_PASS
            string "FTP Password"
            default "Tr2s_76142505"

        config FB_FTP_PORT
            int "Port FTP"
            default 21
            help
                Le port standard est 21.

        config FB_FTP_PATH
            string "Dossier cible"
            default "Freebox/Logs"
            help
                Le dossier sur la Freebox où les fichiers seront stockés.


    endmenu

    menu "Jeedom Configuration"

    config API_KEY
        string "API KEY"
        default "Your Jeedom API Key"
        help
            Your API key.

    config JEEDOM_ENABLE
        bool "Enable Jeedom Integration"
        default false
        help
            Enable Jeedom Integration.

    config JEEDOM_HOST
        string "Jeedom Host"
        default "http://jeedom.local"
        help
            Jeedom Host URL.

    config JEEDOM_PORT
        int "Jeedom Port"
        default 80
        help
            Jeedom Port.

    config JEEDOM_PATH
        string "Jeedom Path"
        default "/core/api/jeeApi.php"
        help
            Jeedom API Path.
        
    endmenu

    menu "Serial Manager"

    config SERIAL_MANAGER_ENABLED
        bool "Enable Serial Manager"
        default y

    endmenu

    menu "WiFi Manager Configuration"
        comment "Parametres du reseau diffuse par l'ESP32"

        config ESP_WIFI_STA_SSID
            string "Station SSID"
            default "freebox-TR2S"

        config ESP_WIFI_STA_PASSWORD
            string "Station password"
            default "cordon-electronics_tr2s"

        config ESP_WIFI_AP_SSID
            string "AP SSID"
            default "Thermostat"
            help
                Nom du WiFi emis par l'appareil pour la configuration initiale ou le secours.

        config ESP_WIFI_AP_PASSWORD
            string "AP password"
            default "12345678"
            help
                Le mot de passe doit comporter au moins 8 caracteres.
                Par defaut : 12345678.

        config ESP_MAXIMUM_STA_RETRY
            int "Nombre de tentatives de reconnexion"
            range 1 100
            default 5
            help
                Nombre de tentatives avant d'activer l'AP de secours.
                Une valeur de 5 est un bon compromis stabilite/vitesse.

        choice ESP_WIFI_SCAN_AUTH_MODE_THRESHOLD
            prompt "Securite minimale acceptee"
            default ESP_WIFI_AUTH_WPA2_PSK
            help
                Niveau de securite minimal pour autoriser la connexion. 
                WPA2 PSK est la norme actuelle pour la plupart des box.

            config ESP_WIFI_AUTH_OPEN
                bool "Ouvert (Aucune)"
            config ESP_WIFI_AUTH_WEP
                bool "WEP (Obsolete)"
            config ESP_WIFI_AUTH_WPA_PSK
                bool "WPA PSK"
            config ESP_WIFI_AUTH_WPA2_PSK
                bool "WPA2 PSK"
            config ESP_WIFI_AUTH_WPA_WPA2_PSK
                bool "WPA/WPA2 PSK"
            config ESP_WIFI_AUTH_WPA3_PSK
                bool "WPA3 PSK"
            config ESP_WIFI_AUTH_WPA2_WPA3_PSK
                bool "WPA2/WPA3 PSK"
        endchoice

        config ESP_WIFI_RETRY_INTERVAL_MS
            int "Intervalle entre retries (ms)"
            range 500 10000
            default 3000
            help
                Delai de "respiration" radio entre deux tentatives de connexion.
                Augmenter cette valeur rend le SoftAP de secours plus visible.

        config ESP_WIFI_AP_CHANNEL
            int "AP channel"
            range 1 13
            default 1
            help
                Canal utilise par le SoftAP. Evitez les canaux encombres par votre box.

        config ESP_MAX_STA_CONN_AP
            int "Nombre max de clients sur l'AP"
            range 1 10
            default 4
            help
                Nombre maximum de téléphones ou PC connectés simultanément à l'ESP32.

    endmenu

    menu "Relais Configuration"

    config RELAY_GPIO_PIN
        int "Relay GPIO Pin"
        range 0 48
        default 18
        help
            Le numero du GPIO sur lequel est branche le relais de commande de la chaudiere.

    config RELAY_INVERTED
        bool "Inverser la logique du relais"
        default n
        help
            Cochez si le relais s'active avec un niveau BAS (0V).

    config RELAY_MIN_DELAY_SEC
        int "Delai minimum entre commutations (secondes)"
        range 0 3600
        default 60
        help
            Empeche le relais de changer d'etat trop rapidement pour proteger la chaudiere.

    endmenu

    menu "Time Configuration"

        config SNTP_SERVER_NAME
            string "SNTP Server Name"
            default "pool.ntp.org"
            help
                L'adresse du serveur NTP à utiliser pour la synchronisation.

        config SNTP_WAIT_FOR_SYNC_MS
            int "Wait for Sync Timeout (ms)"
            default 2000
            range 100 10000
            help
                Temps d'attente maximum en millisecondes pour une réponse du serveur.

        config SNTP_MAX_RETRY
            int "Max Retry Count"
            default 10
            range 1 50
            help
                Nombre maximal de tentatives de reconnexion en cas d'échec.

    endmenu

endmenu